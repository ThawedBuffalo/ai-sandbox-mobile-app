# Jira API credentials (secrets)
JIRA_HOST=
JIRA_EMAIL=
JIRA_API_TOKEN=

# Optional TLS settings for corporate/self-signed certificate chains
# Path to PEM-encoded root/intermediate CA certificate used by your Jira endpoint.
# Example: JIRA_CA_CERT_PATH=certs/corp-root-ca.pem
JIRA_CA_CERT_PATH=

# Temporary local troubleshooting only. Prefer JIRA_CA_CERT_PATH instead.
# true disables TLS certificate verification for Jira calls from scripts.
JIRA_TLS_INSECURE=false

# Non-secret project config (Jira project key, Confluence space, Miro board, Figma file)
# lives in project-config.json — see project-config.template.json
